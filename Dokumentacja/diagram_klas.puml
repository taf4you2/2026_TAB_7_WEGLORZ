@startuml diagram_klas
title Diagram Klas – System Sprzedaży Biletów Narciarskich

skinparam classAttributeIconSize 0

' ─────────────────────────────────────────
'  ENCJE DOMENOWE
' ─────────────────────────────────────────

' UC1, UC10, UC13
class Narciarz {
    - id : int
    - imie : String
    - nazwisko : String
    - email : String
    + pobierzHistoriePrzejazdow() : List<Przejazd>
}

' UC1, UC2, UC3, UC6 – wspólna abstrakcja dla Bilet i Karnet
abstract class Uprawnienie {
    - id : int
    - cena : decimal
    - status : StatusUprawnienia
    - dataWydania : DateTime
    + czyWazny() : bool
    + zablokuj() : void
}

' UC1, UC4 – papierowy bilet jednorazowy, wazny do pierwszego przejazdu
class Bilet {
    + drukuj() : void
}

' UC2, UC4b, UC11, UC12 – fizyczna tabliczka RFID z kaucja, wazna czasowo
class Karnet {
    - numerChipa : String
    - typ : TypKarnetu
    - kaucja : decimal
    - dataWaznosci : DateTime
    - dataZwrotu : DateTime
    + wydaj() : void
    + zwroc() : void
}

enum TypKarnetu {
    DZIENNY
    WIELODNIOWY
    SEZONOWY
}

enum StatusUprawnienia {
    AKTYWNY
    ZABLOKOWANY
    WYGASLY
    WYKORZYSTANY
    ZWROCONY
}

' UC5, UC7, UC13
class Wyciag {
    - id : int
    - nazwa : String
    - lokalizacja : String
    - status : StatusWyciagu
    + pobierzRoklad() : RokladWyciagu
}

enum StatusWyciagu {
    CZYNNY
    NIECZYNNY
    SERWIS
}

' UC7, UC13
class RokladWyciagu {
    - id : int
    - godzinyOtwarcia : Time
    - godzinyZamkniecia : Time
    - dni : List<DzienTygodnia>
    + czyOtwarty(czas: DateTime) : bool
}

' UC5, UC6
class Przejazd {
    - id : int
    - dataGodzina : DateTime
    + zarejestruj() : void
}

' UC8, UC9, UC10
class Raport {
    - id : int
    - typ : TypRaportu
    - dataWygenerowania : DateTime
    - zawartosc : String
    + generuj() : void
    + drukuj() : void
}

enum TypRaportu {
    ZARZADCZY
    OPERACYJNY
    PRZEJAZDOW_NARCIARZA
}

' ─────────────────────────────────────────
'  RELACJE
' ─────────────────────────────────────────

Bilet --|> Uprawnienie : dziedziczy
Karnet --|> Uprawnienie : dziedziczy

Narciarz "1" o-- "0..*" Uprawnienie : posiada

Uprawnienie "1" *-- "0..*" Przejazd : rejestruje

Przejazd "0..*" --> "1" Wyciag : dotyczy

Wyciag "1" *-- "1" RokladWyciagu : ma

Raport "0..*" --> "1" Narciarz : dotyczy
Raport "0..*" --> "0..*" Przejazd : zawiera dane

Karnet --> TypKarnetu
Uprawnienie --> StatusUprawnienia
Wyciag --> StatusWyciagu
Raport --> TypRaportu

@enduml
