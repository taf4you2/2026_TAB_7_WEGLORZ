@startuml diagram_przypadkow_uzycia
title Diagram Przypadków Użycia – System Sprzedaży Biletów Narciarskich

left to right direction
skinparam actorStyle awesome

' Definiuje aktorów.
actor "Narciarz Zalogowany" as NarciarzZalogowany
actor "Narciarz" as Narciarz
NarciarzZalogowany -|> Narciarz

actor "Kasjer" as Kasjer
actor "System Wyciągów" as SystemWyciagow <<system>>
actor "Zarządca" as Zarzadca

' Tworzy główny obszar systemu.
rectangle "System Sprzedaży Biletów Narciarskich" {

    ' Grupuje przypadki użycia strefy online.
    rectangle "Strefa Online" {
        usecase "Kup bilet/karnet online" as UC_KupOnline
        usecase "Zarezerwuj karnet online" as UC_RezerwujOnline
        usecase "Przypisz posiadany karnet do konta" as UC_PrzypiszKarnet
        usecase "Śledź pełną historię zjazdów" as UC_HistoriaZalogowany
    }

    ' Grupuje ogólnodostępne przypadki użycia informacyjne.
    rectangle "Strefa Informacyjna" {
        usecase "Sprawdź historię po numerze karnetu" as UC_HistoriaNumer
        usecase "Sprawdź rozkład wyciągów" as UC_Rozklad
    }

    ' Grupuje przypadki użycia związane z obsługą stacjonarną.
    rectangle "Obsługa Kasowa i Zwroty" {
        usecase "Sprzedaj bilet/karnet w kasie" as UC_SprzedazKasa
        usecase "Wydaj zarezerwowany karnet" as UC_WydajZarezerwowany
        usecase "Wydrukuj bilet" as UC_DrukujBilet
        usecase "Wydaj fizyczny karnet" as UC_WydajKarnet
        usecase "Pobierz kaucję" as UC_PobierzKaucje
        usecase "Zablokuj bilet" as UC_Zablokuj
        usecase "Przypisz karnet do emaila" as UC_PodajEmail
        usecase "Zwróć karnet" as UC_ZwrocKarnet
        usecase "Zwróć kaucję" as UC_ZwrocKaucje
    }

    ' Grupuje przypadki użycia integracji wyciągów.
    rectangle "Obsługa Wyciągów" {
        usecase "Zarejestruj przejazd wyciągiem (Jeździ)" as UC_Jazda
        usecase "Weryfikuj ważność biletu / karnetu" as UC_Weryfikuj
    }

    ' Grupuje przypadki użycia zarządcze.
    rectangle "Zarządzanie" {
        usecase "Zdefiniuj rozkład wyciągów" as UC_ZdefiniujRozklad
        usecase "Generuj raport zarządczy" as UC_RaportZarzadczy
        usecase "Generuj raport operacyjny" as UC_RaportOperacyjny
    }
}

' Przypisuje relacje Narciarza Zalogowanego.
NarciarzZalogowany --> UC_KupOnline
NarciarzZalogowany --> UC_RezerwujOnline
NarciarzZalogowany --> UC_PrzypiszKarnet
NarciarzZalogowany --> UC_HistoriaZalogowany

' Przypisuje relacje podstawowego Narciarza.
Narciarz --> UC_SprzedazKasa
Narciarz --> UC_WydajZarezerwowany
Narciarz --> UC_HistoriaNumer
Narciarz --> UC_Rozklad
Narciarz --> UC_ZwrocKarnet
Narciarz ..> UC_Jazda : inicjuje
Narciarz --> UC_PodajEmail

' Przypisuje relacje Kasjera.
Kasjer --> UC_SprzedazKasa
Kasjer --> UC_WydajZarezerwowany
Kasjer --> UC_Zablokuj
Kasjer --> UC_ZwrocKarnet

' Przypisuje relacje Systemu Wyciągów.
SystemWyciagow --> UC_Jazda

' Przypisuje relacje Zarządcy.
Zarzadca --> UC_ZdefiniujRozklad
Zarzadca --> UC_RaportZarzadczy
Zarzadca --> UC_RaportOperacyjny

' Definiuje zależności include i extend.
UC_SprzedazKasa .> UC_DrukujBilet : <<include>>
UC_SprzedazKasa .> UC_WydajKarnet : <<include>>
UC_WydajZarezerwowany .> UC_WydajKarnet : <<include>>
UC_WydajZarezerwowany .> UC_PobierzKaucje : <<include>>
UC_SprzedazKasa <.. UC_PodajEmail : <<extend>>
UC_ZwrocKarnet .> UC_ZwrocKaucje : <<include>>
UC_Jazda .> UC_Weryfikuj : <<include>>

@enduml