<Window x:Class="KasjerApp.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Kasjerski - Panel Kasjera"
        Width="1180" Height="720"
        MinWidth="860" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DCE8F5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Margin="8,2">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Margin="{TemplateBinding Padding}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1D334F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="224" MinWidth="204"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="18,18,18,14" BorderBrush="#243B5A" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="STACJA ERP"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextWrapping="NoWrap"/>
                    <TextBlock Text="Moduł kasjera"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               FontSize="12"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,12,0,12">
                    <Button x:Name="BtnSellPass" Content="Wydaj karnet" Click="Nav_Click" Tag="sell_pass" Style="{StaticResource NavBtn}" IsEnabled="False"/>
                    <Button x:Name="BtnPasses" Content="Karnety i zwroty" Click="Nav_Click" Tag="passes" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="BtnCards" Content="Karty RFID" Click="Nav_Click" Tag="cards" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="BtnTransactions" Content="Transakcje" Click="Nav_Click" Tag="transactions" Style="{StaticResource NavBtn}"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Padding="16" BorderBrush="#243B5A" BorderThickness="0,1,0,0">
                <StackPanel>
                    <TextBlock x:Name="UserLabel"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>
                    <Button Content="Wyloguj"
                            Click="LogoutBtn_Click"
                            Style="{StaticResource DangerButton}"
                            HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Rectangle Grid.Column="1" Fill="{StaticResource BorderBrush}"/>

        <Grid Grid.Column="2" Background="{StaticResource AppBackgroundBrush}">
            <ContentControl x:Name="ContentArea"/>
        </Grid>
    </Grid>
</Window>
