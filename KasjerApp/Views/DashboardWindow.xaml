<Window x:Class="KasjerApp.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Kasjerski - Panel Kasjera"
        Width="1180" Height="720"
        MinWidth="860" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="ToolTipService.IsEnabled" Value="{DynamicResource TooltipsEnabled}"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="450"/>
            <Setter Property="ToolTipService.ShowDuration" Value="12000"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DCE8F5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Margin="8,2">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Margin="{TemplateBinding Padding}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1D334F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="224" MinWidth="204"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="18,18,18,14" BorderBrush="#243B5A" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="STACJA"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextWrapping="NoWrap"/>
                    <TextBlock Text="Moduł kasjera"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               FontSize="12"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,12,0,12">
                    <Button x:Name="BtnReservations" Content="Rezerwacje" Click="Nav_Click" Tag="reservations" Style="{StaticResource NavBtn}" IsEnabled="False" ToolTip="Wyszukaj rezerwację internetową i przypisz kartę RFID do oczekującego karnetu."/>
                    <Button x:Name="BtnSellPass" Content="Wydaj karnet" Click="Nav_Click" Tag="sell_pass" Style="{StaticResource NavBtn}" ToolTip="Sprzedaj nowy karnet na wolnej karcie RFID."/>
                    <Button x:Name="BtnPasses" Content="Karnety i zwroty" Click="Nav_Click" Tag="passes" Style="{StaticResource NavBtn}" ToolTip="Wyszukaj karnet, wykonaj jego zwrot albo odbierz samą kartę."/>
                    <Button x:Name="BtnCards" Content="Karty RFID" Click="Nav_Click" Tag="cards" Style="{StaticResource NavBtn}" ToolTip="Zarządzaj kartami RFID, blokadami i historią przypisanych karnetów."/>
                    <Button x:Name="BtnTransactions" Content="Transakcje" Click="Nav_Click" Tag="transactions" Style="{StaticResource NavBtn}" ToolTip="Przeglądaj operacje sprzedaży i zwrotów, opcjonalnie dla wybranej daty."/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Padding="16" BorderBrush="#243B5A" BorderThickness="0,1,0,0">
                <StackPanel>
                    <TextBlock x:Name="UserLabel"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>
                    <CheckBox x:Name="TooltipsToggle"
                              Content="Podpowiedzi ekranowe"
                              IsChecked="True"
                              Checked="TooltipsToggle_Changed"
                              Unchecked="TooltipsToggle_Changed"
                              Foreground="#DCE8F5"
                              Margin="0,0,0,10"
                              ToolTip="Włącza lub wyłącza krótkie podpowiedzi wyświetlane po zatrzymaniu kursora nad elementem."/>
                    <Button Content="Wyloguj"
                            Click="LogoutBtn_Click"
                            Style="{StaticResource DangerButton}"
                            HorizontalContentAlignment="Center"
                            ToolTip="Kończy bieżącą sesję kasjera i wraca do ekranu logowania."/>
                </StackPanel>
            </Border>
        </Grid>

        <Rectangle Grid.Column="1" Fill="{StaticResource BorderBrush}"/>

        <Grid Grid.Column="2" Background="{StaticResource AppBackgroundBrush}">
            <ContentControl x:Name="ContentArea"/>
        </Grid>
    </Grid>
</Window>
