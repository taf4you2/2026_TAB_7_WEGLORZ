<Window x:Class="KasjerApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logowanie"
        Width="400" Height="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F2F5">

    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid VerticalAlignment="Center" Margin="0,20">
        <Border Background="White"
                CornerRadius="12"
                Margin="24,10"
                Padding="32"
                MaxWidth="340">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.1" Color="#000000"/>
            </Border.Effect>
            <StackPanel>

                <!-- Tytuł -->
                <TextBlock Text="Logowanie"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#1565C0"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="kasjer@stacja.pl / haslo123"
                           FontSize="13" Foreground="#757575"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- E-mail -->
                <TextBlock Text="Login (e-mail)" FontSize="12" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,6"/>
                <TextBox x:Name="EmailBox"
                         Height="40" Padding="12,8"
                         FontSize="14" VerticalContentAlignment="Center"
                         BorderBrush="#DDD" BorderThickness="1.5"/>

                <!-- Hasło -->
                <TextBlock Text="Hasło" FontSize="12" FontWeight="SemiBold" Foreground="#555" Margin="0,16,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="40" Padding="12,8"
                             FontSize="14" VerticalContentAlignment="Center"
                             BorderBrush="#DDD" BorderThickness="1.5"/>

                <!-- Błąd -->
                <TextBlock x:Name="ErrorText"
                           Foreground="#D32F2F"
                           FontSize="12"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>

                <!-- Przycisk -->
                <Button x:Name="LoginBtn"
                        Content="Zaloguj się"
                        Height="44"
                        Margin="0,28,0,0"
                        Style="{StaticResource PrimaryBtn}"
                        Click="LoginBtn_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
