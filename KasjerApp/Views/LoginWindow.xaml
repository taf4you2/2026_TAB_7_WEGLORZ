<Window x:Class="KasjerApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logowanie"
        Width="520" Height="560"
        MinWidth="420" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid MinHeight="460" Margin="28">
                <Border Style="{StaticResource PanelCard}"
                        MaxWidth="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="28">
                    <StackPanel>
                        <TextBlock Text="Logowanie"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="kasjer@stacja.pl / haslo123"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,24"/>

                        <TextBlock Text="Login (e-mail)" Style="{StaticResource FieldLabelText}"/>
                        <TextBox x:Name="EmailBox"
                                 ToolTip="Wpisz login kasjera w formacie adresu e-mail otrzymany od administratora."/>

                        <TextBlock Text="Hasło" Style="{StaticResource FieldLabelText}" Margin="0,16,0,5"/>
                        <PasswordBox x:Name="PasswordBox"
                                     ToolTip="Wpisz hasło do konta kasjera. Naciśnięcie Enter uruchamia logowanie."/>

                        <TextBlock x:Name="ErrorText"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="12"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>

                        <Button x:Name="LoginBtn"
                                Content="Zaloguj się"
                                Style="{StaticResource PrimaryButton}"
                                Height="40"
                                Margin="0,24,0,0"
                                ToolTip="Sprawdza dane logowania i otwiera panel kasjera."
                                Click="LoginBtn_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
