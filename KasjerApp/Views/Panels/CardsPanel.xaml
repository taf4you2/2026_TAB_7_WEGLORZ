<UserControl x:Class="KasjerApp.Views.Panels.CardsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Karty RFID"
                   FontSize="22" FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,16"/>

        <!-- Filtry + dodaj -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Grid.Column="0" Height="36" Padding="10,8"
                         FontSize="14" BorderBrush="#CCC" BorderThickness="1"
                         VerticalContentAlignment="Center"
                         KeyDown="SearchBox_KeyDown"/>
                <ComboBox x:Name="StatusCombo" Grid.Column="1" Height="36" Margin="8,0,0,0"
                          FontSize="13" SelectedIndex="0">
                    <ComboBoxItem Content="(wszystkie statusy)"/>
                    <ComboBoxItem Content="wolna"/>
                    <ComboBoxItem Content="zajeta"/>
                    <ComboBoxItem Content="zastrzezony"/>
                </ComboBox>
                <Button Grid.Column="2" Content="Szukaj" Click="SearchBtn_Click"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        Padding="14,0" Margin="8,0,0,0" Height="36" Cursor="Hand"/>
                <Button Grid.Column="3" Content="↺ Odśwież" Click="RefreshBtn_Click"
                        Background="#00897B" Foreground="White" BorderThickness="0"
                        Padding="12,0" Margin="6,0,0,0" Height="36" Cursor="Hand"/>
                <Button Grid.Column="4" Content="+ Dodaj kartę" Click="AddCardBtn_Click"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        Padding="14,0" Margin="8,0,0,0" Height="36" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- DataGrid kart -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Margin="0,0,0,4">
            <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
            <DataGrid x:Name="CardsGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White" AlternatingRowBackground="#F9FAFB"
                      BorderThickness="0" CanUserResizeRows="False"
                      HeadersVisibility="Column" ColumnHeaderHeight="40"
                      SelectionChanged="CardsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="RFID"          Binding="{Binding Id}"            Width="140"/>
                    <DataGridTextColumn Header="Status"        Binding="{Binding Status}"        Width="100"/>
                    <DataGridTextColumn Header="Właściciel"    Binding="{Binding Owner}"         Width="160"/>
                    <DataGridTextColumn Header="Aktywny karnet" Binding="{Binding ActivePassType}" Width="130"/>
                    <DataGridTextColumn Header="Ważny do"      Binding="{Binding ValidTo, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridCheckBoxColumn Header="Kaucja"    Binding="{Binding DepositPaid}"   Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Nagłówek historii karnetów + komunikat błędu -->
        <Border Grid.Row="3" Background="#E3F2FD" CornerRadius="4" Padding="12,6" Margin="0,8,0,4">
            <StackPanel>
                <TextBlock x:Name="PassesLabel" Text="Historia karnetów – wybierz kartę powyżej"
                           FontSize="13" FontWeight="SemiBold" Foreground="#1565C0"/>
                <TextBlock x:Name="PassesErrorText" Foreground="#C62828" FontSize="12"
                           Visibility="Collapsed" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- DataGrid historii karnetów -->
        <Border Grid.Row="4" Background="White" CornerRadius="8" Margin="0,0,0,12">
            <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
            <DataGrid x:Name="PassesGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          RowBackground="White"
                          AlternatingRowBackground="#F9FAFB"
                          BorderThickness="0"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          ColumnHeaderHeight="38">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"            Binding="{Binding Id}"          Width="60"/>
                        <DataGridTextColumn Header="Status"        Binding="{Binding Status}"      Width="110"/>
                        <DataGridTextColumn Header="Taryfa"        Binding="{Binding Tariff}"      Width="160"/>
                        <DataGridTextColumn Header="Typ"           Binding="{Binding PassType}"    Width="110"/>
                        <DataGridTextColumn Header="Ważny od"      Binding="{Binding ValidFrom, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Ważny do"      Binding="{Binding ValidTo,   StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Powód blokady" Binding="{Binding BlockReason}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
        </Border>

        <!-- Komunikat -->
        <TextBlock x:Name="MsgText" Grid.Row="5"
                   Foreground="#C62828" FontSize="12" Visibility="Collapsed"/>
    </Grid>
</UserControl>
