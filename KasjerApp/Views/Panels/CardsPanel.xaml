<UserControl x:Class="KasjerApp.Views.Panels.CardsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.25*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Karty RFID" Style="{StaticResource PageTitleText}"/>

        <Border Grid.Row="1" Style="{StaticResource FilterPanel}">
            <DockPanel LastChildFill="True">
                <WrapPanel DockPanel.Dock="Right" Margin="8,0,0,0">
                    <ComboBox x:Name="StatusCombo"
                              Width="140"
                              Margin="0,0,8,8"
                              SelectedIndex="0"
                              ToolTip="Ogranicza wyniki do kart o wybranym statusie. Wartość wszystkie wyłącza filtr statusu.">
                        <ComboBoxItem Content="(wszystkie)"/>
                        <ComboBoxItem Content="wolna"/>
                        <ComboBoxItem Content="zajeta"/>
                        <ComboBoxItem Content="zastrzezony"/>
                        <ComboBoxItem Content="usunieta"/>
                    </ComboBox>
                    <Button Content="Szukaj"
                            Click="SearchBtn_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,8"
                            ToolTip="Wyszukuje karty według wpisanego numeru lub wybranego statusu."/>
                    <Button Content="Odśwież"
                            Click="RefreshBtn_Click"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,8"
                            ToolTip="Ponownie pobiera listę kart z aktualnymi filtrami."/>
                    <Button Content="Dodaj kartę"
                            Click="AddCardBtn_Click"
                            Style="{StaticResource SuccessButton}"
                            Margin="0,0,8,8"
                            ToolTip="Rejestruje nową fizyczną kartę RFID w systemie jako wolną."/>
                    <Button Content="Oznacz usuniętą"
                            Click="DeleteCardBtn_Click"
                            Style="{StaticResource DangerButton}"
                            Margin="0,0,8,8"
                            ToolTip="Trwale wycofuje kartę z użycia przez zmianę statusu na usunięta. Operacja wymaga potwierdzenia."/>
                    <Button x:Name="BlockBtn"
                            Content="Zablokuj kartę"
                            Click="BlockBtn_Click"
                            IsEnabled="False"
                            Style="{StaticResource WarningButton}"
                            Margin="0,0,8,8"
                            ToolTip="Zastrzega wybraną kartę i wymaga podania powodu. Najpierw wybierz kartę, która nie jest zastrzeżona ani usunięta."/>
                    <Button x:Name="UnblockBtn"
                            Content="Odblokuj kartę"
                            Click="UnblockBtn_Click"
                            IsEnabled="False"
                            Style="{StaticResource SuccessButton}"
                            Margin="0,0,8,8"
                            ToolTip="Przywraca wybraną zastrzeżoną kartę do użycia. Najpierw wybierz kartę ze statusem zastrzeżony."/>
                    <Button x:Name="ReturnCardBtn"
                            Content="Zwróć kartę"
                            Click="ReturnCardBtn_Click"
                            IsEnabled="False"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,12,8"
                            ToolTip="Odbiera fizyczną kartę, rozlicza należną kaucję i wygasza aktywne karnety bez refundu."/>
                    <TextBlock x:Name="MsgText"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource DangerBrush}"
                               Margin="0,0,0,8"/>
                </WrapPanel>
                <TextBox x:Name="SearchBox"
                         MinWidth="180"
                         Margin="0,0,0,8"
                         KeyDown="SearchBox_KeyDown"
                         ToolTip="Wpisz pełny lub częściowy numer RFID albo dane właściciela. Enter uruchamia wyszukiwanie."/>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelCard}" Padding="0" Margin="0,0,0,10">
            <DataGrid x:Name="CardsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      SelectionChanged="CardsGrid_SelectionChanged"
                      ToolTip="Wybierz kartę, aby zobaczyć jej historię karnetów i uaktywnić dozwolone operacje.">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="RFID" Binding="{Binding Id}" Width="150" MinWidth="120"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" MinWidth="95"/>
                    <DataGridTextColumn Header="Właściciel" Binding="{Binding Owner}" Width="2*" MinWidth="160"/>
                    <DataGridTextColumn Header="ID karnetu" Binding="{Binding ActivePassId}" Width="100" MinWidth="90"/>
                    <DataGridTextColumn Header="Aktywny karnet" Binding="{Binding ActivePassType}" Width="2*" MinWidth="160"/>
                    <DataGridTextColumn Header="Ważny do" Binding="{Binding ValidTo, StringFormat=dd.MM.yyyy HH:mm}" Width="140" MinWidth="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3"
                Style="{StaticResource InfoBorder}"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock x:Name="PassesLabel"
                           Text="Historia karnetów - wybierz kartę powyżej"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock x:Name="PassesErrorText"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="12"
                           Visibility="Collapsed"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource PanelCard}" Padding="0" Margin="0,0,0,12">
            <DataGrid x:Name="PassesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      SelectionChanged="PassesGrid_SelectionChanged"
                      ToolTip="Historia wszystkich karnetów przypisanych do wybranej karty RFID.">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" MinWidth="60"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" MinWidth="95"/>
                    <DataGridTextColumn Header="Taryfa" Binding="{Binding Tariff}" Width="2*" MinWidth="170"/>
                    <DataGridTextColumn Header="Typ" Binding="{Binding PassType}" Width="130" MinWidth="110"/>
                    <DataGridTextColumn Header="Ważny od" Binding="{Binding ValidFrom, StringFormat=dd.MM.yyyy HH:mm}" Width="140" MinWidth="130"/>
                    <DataGridTextColumn Header="Ważny do" Binding="{Binding ValidTo, StringFormat=dd.MM.yyyy HH:mm}" Width="140" MinWidth="130"/>
                    <DataGridTextColumn Header="Zjazdy" Binding="{Binding RemainingRides}" Width="90" MinWidth="80"/>
                    <DataGridTextColumn Header="Powód blokady" Binding="{Binding BlockReason}" Width="2*" MinWidth="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
