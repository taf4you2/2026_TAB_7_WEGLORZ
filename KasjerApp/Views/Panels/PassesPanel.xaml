<UserControl x:Class="KasjerApp.Views.Panels.PassesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}"
             Loaded="PassesPanel_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Karnety i zwroty" Style="{StaticResource PageTitleText}"/>

        <Border Grid.Row="1" Style="{StaticResource FilterPanel}">
            <DockPanel LastChildFill="True">
                <WrapPanel DockPanel.Dock="Right" Margin="8,0,0,0">
                    <Button Content="Szukaj"
                            Click="SearchBtn_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,8"
                            ToolTip="Wyszukuje karnety przez numer RFID lub dane dostępne w wyszukiwarce kart."/>
                    <Button Content="Odśwież"
                            Click="RefreshBtn_Click"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,8"
                            ToolTip="Ponownie pobiera listę karnetów z zachowaniem wpisanego filtra."/>
                    <Button x:Name="ReturnBtn"
                            Content="Zwróć karnet"
                            Click="ReturnBtn_Click"
                            IsEnabled="False"
                            Style="{StaticResource DangerButton}"
                            Margin="0,0,8,8"
                            ToolTip="Oblicza zwrot za niewykorzystany okres i otwiera okno zatwierdzenia. Najpierw wybierz karnet z listy."/>
                    <Button x:Name="ReturnCardOnlyBtn"
                            Content="Odbierz kartę"
                            Click="ReturnCardOnlyBtn_Click"
                            IsEnabled="False"
                            Style="{StaticResource WarningButton}"
                            Margin="0,0,12,8"
                            ToolTip="Odbiera fizyczną kartę i wypłaca kaucję bez zwrotu opłaty za karnet. Aktywne karnety zostaną wygaszone."/>
                    <TextBlock x:Name="ActionMsg"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                </WrapPanel>
                <TextBox x:Name="SearchBox"
                         MinWidth="180"
                         Margin="0,0,0,8"
                         KeyDown="SearchBox_KeyDown"
                         ToolTip="Wpisz pełny lub częściowy numer RFID. Enter uruchamia wyszukiwanie."/>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelCard}" Padding="0" Margin="0,0,0,12">
            <DataGrid x:Name="PassesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      SelectionChanged="PassesGrid_SelectionChanged"
                      ToolTip="Wybierz karnet, aby uaktywnić operację zwrotu karnetu lub odbioru karty.">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID karnetu" Binding="{Binding PassId}" Width="90" MinWidth="80"/>
                    <DataGridTextColumn Header="RFID" Binding="{Binding CardId}" Width="150" MinWidth="120"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" MinWidth="95"/>
                    <DataGridTextColumn Header="Taryfa" Binding="{Binding Tariff}" Width="2*" MinWidth="180"/>
                    <DataGridTextColumn Header="Typ" Binding="{Binding PassType}" Width="130" MinWidth="110"/>
                    <DataGridTextColumn Header="Ważny od" Binding="{Binding ValidFrom, StringFormat=dd.MM.yyyy HH:mm}" Width="140" MinWidth="130"/>
                    <DataGridTextColumn Header="Ważny do" Binding="{Binding ValidTo, StringFormat=dd.MM.yyyy HH:mm}" Width="140" MinWidth="130"/>
                    <DataGridTextColumn Header="Zjazdy" Binding="{Binding RemainingRides}" Width="90" MinWidth="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
