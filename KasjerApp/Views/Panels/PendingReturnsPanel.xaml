<UserControl x:Class="KasjerApp.Views.Panels.PendingReturnsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,14">
            <WrapPanel DockPanel.Dock="Right" Margin="12,0,0,0">
                <Button Content="Odśwież"
                        Click="RefreshBtn_Click"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,12,8"/>
                <Button x:Name="ReturnBtn"
                        Content="Zatwierdź zwrot"
                        Click="ReturnBtn_Click"
                        IsEnabled="False"
                        Style="{StaticResource DangerButton}"
                        Margin="0,0,12,8"/>
                <TextBlock x:Name="MsgText"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource DangerBrush}"
                           Visibility="Collapsed"
                           Margin="0,0,0,8"/>
            </WrapPanel>
            <TextBlock Text="Oczekujące zwroty karnetów" Style="{StaticResource PageTitleText}" Margin="0,0,0,8"/>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource PanelCard}" Padding="0" Margin="0,0,0,12">
            <DataGrid x:Name="ReturnsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      SelectionChanged="ReturnsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID karnetu" Binding="{Binding PassId}" Width="90" MinWidth="80"/>
                    <DataGridTextColumn Header="RFID" Binding="{Binding CardRfid}" Width="130" MinWidth="110"/>
                    <DataGridTextColumn Header="Email właśc." Binding="{Binding OwnerEmail}" Width="2*" MinWidth="180"/>
                    <DataGridTextColumn Header="Typ" Binding="{Binding PassType}" Width="130" MinWidth="110"/>
                    <DataGridTextColumn Header="Ważny do" Binding="{Binding ValidTo, StringFormat=dd.MM.yyyy HH:mm}" Width="140" MinWidth="130"/>
                    <DataGridTextColumn Header="Dni pozostałe" Binding="{Binding RemainingDays}" Width="115" MinWidth="105"/>
                    <DataGridTextColumn Header="Szac. zwrot" Binding="{Binding EstimatedRefund, StringFormat=N2}" Width="120" MinWidth="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2"
                x:Name="DetailsBorder"
                Style="{StaticResource InfoBorder}"
                Margin="0,0,0,10"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Szczegóły wybranego zwrotu" Style="{StaticResource SectionHeaderText}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,12,8">
                        <TextBlock Text="ID karnetu" Style="{StaticResource FieldLabelText}"/>
                        <TextBlock x:Name="DetailPassId" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,12,8">
                        <TextBlock Text="RFID karty" Style="{StaticResource FieldLabelText}"/>
                        <TextBlock x:Name="DetailCardRfid" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Właściciel" Style="{StaticResource FieldLabelText}"/>
                        <TextBlock x:Name="DetailOwnerEmail" FontSize="13" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,12,0">
                        <TextBlock Text="Typ karnetu" Style="{StaticResource FieldLabelText}"/>
                        <TextBlock x:Name="DetailPassType" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,12,0">
                        <TextBlock Text="Dni pozostałe" Style="{StaticResource FieldLabelText}"/>
                        <TextBlock x:Name="DetailRemainingDays" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="1">
                        <TextBlock Text="Szacowany zwrot" Style="{StaticResource FieldLabelText}"/>
                        <TextBlock x:Name="DetailEstimatedRefund" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3"
                   x:Name="ActionMsg"
                   FontSize="13"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   TextWrapping="Wrap"/>
    </Grid>
</UserControl>
