<UserControl x:Class="KasjerApp.Views.Panels.PendingReturnsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Oczekujące zwroty karnetów"
                       FontSize="22" FontWeight="Bold" Foreground="#1565C0" VerticalAlignment="Center"/>
            <Button Content="Odśwież" Click="RefreshBtn_Click"
                    Background="#1565C0" Foreground="White" BorderThickness="0"
                    Padding="16,7" Margin="20,0,0,0" FontSize="13" Cursor="Hand"/>
            <TextBlock x:Name="MsgText" VerticalAlignment="Center"
                       Margin="16,0,0,0" FontSize="12" Foreground="#C62828"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- DataGrid -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Margin="0,0,0,16">
            <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
            <DataGrid x:Name="ReturnsGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White" AlternatingRowBackground="#F9FAFB"
                      BorderThickness="0" CanUserResizeRows="False"
                      HeadersVisibility="Column" ColumnHeaderHeight="40"
                      SelectionChanged="ReturnsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID karnetu"   Binding="{Binding PassId}"                                 Width="90"/>
                    <DataGridTextColumn Header="RFID"         Binding="{Binding CardRfid}"                               Width="120"/>
                    <DataGridTextColumn Header="Email właśc." Binding="{Binding OwnerEmail}"                             Width="180"/>
                    <DataGridTextColumn Header="Typ"          Binding="{Binding PassType}"                               Width="120"/>
                    <DataGridTextColumn Header="Ważny do"     Binding="{Binding ValidTo, StringFormat=dd.MM.yyyy}"       Width="100"/>
                    <DataGridTextColumn Header="Dni pozostałe" Binding="{Binding RemainingDays}"                         Width="100"/>
                    <DataGridTextColumn Header="Szac. zwrot"  Binding="{Binding EstimatedRefund, StringFormat=N2}"       Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Akcja -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="16">
            <Border.Effect><DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08"/></Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ReturnBtn" Content="↩  Zatwierdź zwrot" Click="ReturnBtn_Click"
                        IsEnabled="False"
                        Background="#C62828" Foreground="White" BorderThickness="0"
                        Padding="16,10" FontSize="13" Cursor="Hand"/>
                <TextBlock x:Name="ActionMsg" VerticalAlignment="Center"
                           Margin="16,0,0,0" FontSize="12" Foreground="#555"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
