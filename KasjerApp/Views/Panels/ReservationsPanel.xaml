<UserControl x:Class="KasjerApp.Views.Panels.ReservationsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Rezerwacje online" Style="{StaticResource PageTitleText}"/>

        <Border Grid.Row="1" Style="{StaticResource FilterPanel}">
            <DockPanel LastChildFill="True">
                <WrapPanel DockPanel.Dock="Right" Margin="8,0,0,0">
                    <Button Content="Szukaj"
                            Click="SearchBtn_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,8"/>
                    <Button Content="Wyczyść"
                            Click="ClearBtn_Click"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,12,8"/>
                    <TextBlock x:Name="SearchMsg"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                </WrapPanel>
                <StackPanel>
                    <TextBlock Text="Email narciarza" Style="{StaticResource FieldLabelText}"/>
                    <TextBox x:Name="EmailBox"
                             MinWidth="240"
                             KeyDown="EmailBox_KeyDown"
                             PreviewKeyDown="EmailBox_PreviewKeyDown"
                             TextChanged="EmailBox_TextChanged"
                             LostFocus="EmailBox_LostFocus"/>
                    <Popup x:Name="SuggestionsPopup"
                           PlacementTarget="{Binding ElementName=EmailBox}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           Focusable="False">
                        <Border Background="White"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ListBox x:Name="SuggestionsList"
                                     MinWidth="240"
                                     MaxHeight="180"
                                     BorderThickness="0"
                                     DisplayMemberPath="Email"
                                     PreviewKeyDown="SuggestionsList_PreviewKeyDown"
                                     PreviewMouseLeftButtonUp="SuggestionsList_PreviewMouseLeftButtonUp"/>
                        </Border>
                    </Popup>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCard}" Padding="0">
                <DataGrid x:Name="ReservationsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="0"
                          SelectionChanged="ReservationsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nr rezerwacji" Binding="{Binding ReservationNumber}" Width="170" MinWidth="150"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding ReservationDate, StringFormat=dd.MM.yyyy HH:mm}" Width="135" MinWidth="120"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="125" MinWidth="110"/>
                        <DataGridTextColumn Header="Do wydania" Binding="{Binding PendingCount}" Width="90" MinWidth="80"/>
                        <DataGridTextColumn Header="Realizacja" Binding="{Binding RealizationStatus}" Width="120" MinWidth="105"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ActionPanel}" Margin="0,0,0,12">
                    <DockPanel LastChildFill="True">
                        <Button x:Name="AcceptReservationBtn"
                                DockPanel.Dock="Right"
                                Content="Zatwierdź do realizacji"
                                Click="AcceptReservationBtn_Click"
                                IsEnabled="False"
                                Style="{StaticResource SuccessButton}"
                                Margin="12,0,0,0"/>
                        <TextBlock x:Name="SelectedReservationText"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Wybierz rezerwację z listy."/>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource PanelCard}" Padding="0">
                    <DataGrid x:Name="PassesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              BorderThickness="0"
                              SelectionChanged="PassesGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID karnetu" Binding="{Binding Id}" Width="82" MinWidth="72"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130" MinWidth="115"/>
                            <DataGridTextColumn Header="Taryfa" Binding="{Binding Tariff}" Width="2*" MinWidth="160"/>
                            <DataGridTextColumn Header="Cena" Binding="{Binding Price, StringFormat=N2}" Width="80" MinWidth="70"/>
                            <DataGridTextColumn Header="Ważny od" Binding="{Binding ValidFrom, StringFormat=dd.MM.yyyy HH:mm}" Width="135" MinWidth="120"/>
                            <DataGridTextColumn Header="Ważny do" Binding="{Binding ValidTo, StringFormat=dd.MM.yyyy HH:mm}" Width="135" MinWidth="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource ActionPanel}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Karta RFID dla wybranego karnetu" Style="{StaticResource FieldLabelText}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RfidBox" Grid.Column="0"/>
                            <ComboBox x:Name="FreeCardCombo"
                                      Grid.Column="2"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="FreeCardCombo_SelectionChanged"/>
                        </Grid>
                        <DockPanel LastChildFill="True">
                            <Button x:Name="IssueCardBtn"
                                    DockPanel.Dock="Right"
                                    Content="Wydaj kartę"
                                    Click="IssueCardBtn_Click"
                                    IsEnabled="False"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="12,0,0,0"
                                    MinWidth="132"/>
                            <TextBlock x:Name="IssueMsg"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="3"
                x:Name="StatusBorder"
                CornerRadius="4"
                BorderThickness="1"
                Padding="12,8"
                Margin="0,12,0,0"
                Visibility="Collapsed">
            <TextBlock x:Name="StatusText" FontSize="13" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
