<Window x:Class="KasjerApp.Views.Panels.ReturnDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zwrot karnetu"
        Width="540" Height="400"
        MinWidth="420" MinHeight="330"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Zwrot karnetu" Style="{StaticResource PageTitleText}"/>

        <Border Grid.Row="1" Style="{StaticResource PanelCard}" Margin="0,0,0,14">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Podgląd kalkulacji zwrotu:" Style="{StaticResource FieldLabelText}"/>
                    <TextBlock x:Name="PreviewText"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Text="Ładowanie..."/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <CheckBox x:Name="ReturnCardCheck"
                      Content="Zwróć również kartę i wypłać kaucję"
                      IsChecked="True"
                      Margin="0,0,0,10"
                      Checked="ReturnCardCheck_Changed"
                      Unchecked="ReturnCardCheck_Changed"
                      ToolTip="Zaznacz, jeśli klient oddaje również fizyczną kartę i ma otrzymać należną kaucję. Zmiana aktualizuje kalkulację."/>
            <TextBlock Text="Powód zwrotu:" Style="{StaticResource FieldLabelText}"/>
            <TextBox x:Name="ReasonBox"
                     ToolTip="Podaj krótki, rzeczowy powód zwrotu. Pole jest wymagane."/>
        </StackPanel>

        <WrapPanel Grid.Row="3" HorizontalAlignment="Right">
            <Button Content="Anuluj"
                    Click="CancelBtn_Click"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,10,0"
                    ToolTip="Zamyka okno bez wykonania zwrotu."/>
            <Button Content="Zatwierdź zwrot"
                    Click="ConfirmBtn_Click"
                    Style="{StaticResource DangerButton}"
                    ToolTip="Przekazuje zatwierdzony zwrot do realizacji. Przed kliknięciem sprawdź kalkulację i opcję zwrotu karty."/>
        </WrapPanel>
    </Grid>
</Window>
