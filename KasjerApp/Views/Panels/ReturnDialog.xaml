<Window x:Class="KasjerApp.Views.Panels.ReturnDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zwrot karnetu"
        Width="480" SizeToContent="Height" MinHeight="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F2F5">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Zwrot karnetu" FontSize="18" FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Border.Effect><DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
            <StackPanel>
                <TextBlock Text="Podglad kalkulacji zwrotu:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="PreviewText" Foreground="#555" FontSize="12" TextWrapping="Wrap" Text="Ladowanie..."/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="Powod zwrotu:" FontSize="12" Foreground="#444" Margin="0,0,0,4"/>
            <TextBox x:Name="ReasonBox" Height="36" Padding="10,8" FontSize="14" BorderBrush="#CCC" BorderThickness="1" VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Anuluj" Click="CancelBtn_Click" Background="#EEE" Foreground="#333" BorderThickness="0" Padding="16,9" Margin="0,0,12,0"/>
            <Button Content="Zatwierdz zwrot" Click="ConfirmBtn_Click" Background="#C62828" Foreground="White" BorderThickness="0" Padding="16,9" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
