<UserControl x:Class="KasjerApp.Views.Panels.SellPassPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24" MaxWidth="600" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="UC2 – Sprzedaj karnet"
                       FontSize="22" FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,20"/>

            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                <StackPanel>

                    <!-- RFID -->
                    <TextBlock Text="RFID karty" FontSize="12" Foreground="#444" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RfidBox" Grid.Column="0" Height="36" Padding="10,8"
                                 FontSize="14" BorderBrush="#CCC" BorderThickness="1"
                                 VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="Weryfikuj" Click="VerifyCard_Click"
                                Background="#1565C0" Foreground="White" BorderThickness="0"
                                Padding="14,0" Margin="8,0,0,0" Height="36" Cursor="Hand"/>
                    </Grid>

                    <!-- Dropdown wolnych kart RFID -->
                    <TextBlock Text="Lub wybierz wolną kartę z listy:" FontSize="11"
                               Foreground="#666" Margin="0,0,0,4"/>
                    <ComboBox x:Name="FreeCardCombo" Height="34" Margin="0,0,0,16"
                              DisplayMemberPath="DisplayName" FontSize="13"
                              SelectionChanged="FreeCardCombo_SelectionChanged"
                              Background="White" BorderBrush="#BBDEFB"/>

                    <!-- Status karty -->
                    <Border x:Name="CardInfoBorder" Background="#E3F2FD" CornerRadius="6" Padding="12,8"
                            Margin="0,0,0,16" Visibility="Collapsed">
                        <TextBlock x:Name="CardInfoText" Foreground="#1565C0" FontSize="13" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Taryfa -->
                    <TextBlock Text="Taryfa karnetu" FontSize="12" Foreground="#444" Margin="0,0,0,4"/>
                    <ComboBox x:Name="TariffCombo" Height="36" Margin="0,0,0,16"
                              DisplayMemberPath="DisplayName" FontSize="14"
                              SelectionChanged="TariffCombo_SelectionChanged"/>

                    <!-- Daty -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ważny od" FontSize="12" Foreground="#444" Margin="0,0,0,4"/>
                            <DatePicker x:Name="ValidFromPicker" Height="36" FontSize="14"
                                        SelectedDateFormat="Short"
                                        SelectedDateChanged="ValidFromPicker_SelectedDateChanged"
                                        ToolTip="Kliknij strzałkę ▼, aby otworzyć kalendarz"/>
                            <TextBlock Text="dd.MM.rrrr" FontSize="10" Foreground="#AAA" Margin="2,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ważny do" FontSize="12" Foreground="#444" Margin="0,0,0,4"/>
                            <DatePicker x:Name="ValidToPicker" Height="36" FontSize="14"
                                        SelectedDateFormat="Short"
                                        ToolTip="Wypełniane automatycznie na podstawie taryfy"/>
                            <TextBlock Text="dd.MM.rrrr" FontSize="10" Foreground="#AAA" Margin="2,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Narciarz (opcjonalne) -->
                    <TextBlock Text="Narciarz – email (opcjonalne)" FontSize="12" Foreground="#444" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UserEmailBox" Grid.Column="0" Height="36" Padding="10,8"
                                 FontSize="14" BorderBrush="#CCC" BorderThickness="1"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Wpisz fragment adresu email narciarza i kliknij Szukaj"/>
                        <Button Grid.Column="1" Content="Szukaj" Click="UserSearch_Click"
                                Background="#546E7A" Foreground="White" BorderThickness="0"
                                Padding="14,0" Margin="8,0,0,0" Height="36" Cursor="Hand"/>
                    </Grid>
                    <Border x:Name="UserInfoBorder" CornerRadius="6" Padding="10,7"
                            Margin="0,0,0,8" Visibility="Collapsed">
                        <TextBlock x:Name="UserInfoText" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                    <ComboBox x:Name="UserResultCombo" Height="34" Margin="0,0,0,12"
                              DisplayMemberPath="DisplayName" FontSize="13"
                              SelectionChanged="UserResultCombo_SelectionChanged"
                              Visibility="Collapsed" Background="White" BorderBrush="#CE93D8"/>

                    <!-- Błąd -->
                    <TextBlock x:Name="ErrorText" Foreground="#C62828" FontSize="12"
                               Visibility="Collapsed" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <Button Content="Sprzedaj karnet" Click="SellBtn_Click"
                            Background="#2E7D32" Foreground="White" BorderThickness="0"
                            Height="42" FontSize="15" FontWeight="SemiBold" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- Potwierdzenie -->
            <Border Grid.Row="2" x:Name="ConfirmBorder" Background="#E8F5E9" CornerRadius="8"
                    Padding="20" Visibility="Collapsed">
                <Border.Effect><DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="✓ Karnet sprzedany pomyślnie" FontSize="15" FontWeight="Bold"
                               Foreground="#2E7D32" Margin="0,0,0,8"/>
                    <TextBlock x:Name="ConfirmText" Foreground="#1B5E20" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
