<UserControl x:Class="KasjerApp.Views.Panels.SellPassPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20" MaxWidth="860" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Wydaj karnet na kartę" Style="{StaticResource PageTitleText}"/>

            <Border Grid.Row="1" Style="{StaticResource PanelCard}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="RFID karty" Style="{StaticResource FieldLabelText}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RfidBox" Grid.Column="0"/>
                        <Button Grid.Column="1"
                                Content="Weryfikuj"
                                Click="VerifyCard_Click"
                                Style="{StaticResource PrimaryButton}"
                                Margin="8,0,0,0"/>
                    </Grid>

                    <TextBlock Text="Lub wybierz wolną kartę z listy:" Style="{StaticResource MutedText}" Margin="0,0,0,5"/>
                    <ComboBox x:Name="FreeCardCombo"
                              Margin="0,0,0,16"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="FreeCardCombo_SelectionChanged"/>

                    <Border x:Name="CardInfoBorder"
                            Style="{StaticResource InfoBorder}"
                            Margin="0,0,0,16"
                            Visibility="Collapsed">
                        <TextBlock x:Name="CardInfoText" Foreground="{StaticResource PrimaryBrush}" FontSize="13" TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Taryfa karnetu" Style="{StaticResource FieldLabelText}"/>
                    <ComboBox x:Name="TariffCombo"
                              Margin="0,0,0,16"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="TariffCombo_SelectionChanged"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start" Style="{StaticResource FieldLabelText}"/>
                            <DatePicker x:Name="ValidFromPicker"
                                        SelectedDateFormat="Short"
                                        SelectedDateChanged="ValidFromPicker_SelectedDateChanged"/>
                            <TextBox x:Name="ValidFromTimeBox"
                                     Text="08:00"
                                     Margin="0,6,0,0"
                                     TextChanged="ValidFromTimeBox_TextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Koniec" Style="{StaticResource FieldLabelText}"/>
                            <Border Background="{StaticResource SurfaceMutedBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    Padding="10,8"
                                    MinHeight="34">
                                <TextBlock x:Name="ValidToText" FontSize="13"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Narciarz - email (opcjonalne)" Style="{StaticResource FieldLabelText}"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UserEmailBox"
                                 Grid.Column="0"
                                 KeyDown="UserEmailBox_KeyDown"
                                 TextChanged="UserEmailBox_TextChanged"/>
                        <Button Grid.Column="1"
                                Content="Szukaj"
                                Click="UserSearch_Click"
                                Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0"/>
                    </Grid>

                    <Border x:Name="UserInfoBorder"
                            CornerRadius="4"
                            BorderThickness="1"
                            Padding="10,7"
                            Margin="0,0,0,8"
                            Visibility="Collapsed">
                        <TextBlock x:Name="UserInfoText" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                    <ListBox x:Name="UserResultsList"
                             Margin="0,0,0,12"
                             MaxHeight="132"
                             DisplayMemberPath="DisplayName"
                             SelectionChanged="UserResultsList_SelectionChanged"
                             Visibility="Collapsed"
                             Background="White"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"/>

                    <TextBlock x:Name="ErrorText"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="12"
                               Visibility="Collapsed"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <Button Content="Wydaj karnet"
                            Click="SellBtn_Click"
                            Style="{StaticResource SuccessButton}"
                            Height="40"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    x:Name="ConfirmBorder"
                    Style="{StaticResource SuccessInfoBorder}"
                    Padding="16"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Karnet wydany pomyślnie"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="ConfirmText" Foreground="{StaticResource SuccessBrush}" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
