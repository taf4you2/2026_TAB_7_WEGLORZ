<UserControl x:Class="KasjerApp.Views.Panels.SellTicketPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20" MaxWidth="820" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Sprzedaj bilet jednorazowy" Style="{StaticResource PageTitleText}"/>

            <Border Grid.Row="1" Style="{StaticResource PanelCard}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="RFID karty" Style="{StaticResource FieldLabelText}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RfidBox" Grid.Column="0"/>
                        <Button Grid.Column="1"
                                Content="Weryfikuj"
                                Click="VerifyCard_Click"
                                Style="{StaticResource PrimaryButton}"
                                Margin="8,0,0,0"/>
                    </Grid>

                    <TextBlock Text="Lub wybierz wolną kartę z listy:" Style="{StaticResource MutedText}" Margin="0,0,0,5"/>
                    <ComboBox x:Name="FreeCardCombo"
                              Margin="0,0,0,16"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="FreeCardCombo_SelectionChanged"/>

                    <Border x:Name="CardInfoBorder"
                            Background="#E8F2FC"
                            BorderBrush="#B8D5F2"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12,8"
                            Margin="0,0,0,16"
                            Visibility="Collapsed">
                        <TextBlock x:Name="CardInfoText" Foreground="{StaticResource PrimaryBrush}" FontSize="13" TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Taryfa" Style="{StaticResource FieldLabelText}"/>
                    <ComboBox x:Name="TariffCombo"
                              Margin="0,0,0,16"
                              DisplayMemberPath="DisplayName"/>

                    <TextBlock Text="Data ważności" Style="{StaticResource FieldLabelText}"/>
                    <DatePicker x:Name="ValidOnPicker" Margin="0,0,0,16"/>

                    <TextBlock Text="Liczba zjazdów (1-50)" Style="{StaticResource FieldLabelText}"/>
                    <TextBox x:Name="QuantityBox"
                             Text="1"
                             Margin="0,0,0,18"/>

                    <TextBlock x:Name="ErrorText"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="12"
                               Visibility="Collapsed"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <Button Content="Sprzedaj bilet"
                            Click="SellBtn_Click"
                            Style="{StaticResource SuccessButton}"
                            Height="40"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    x:Name="ConfirmBorder"
                    Background="#E8F5EF"
                    BorderBrush="#B8DDCD"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="16"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Bilet sprzedany pomyślnie"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="ConfirmText" Foreground="{StaticResource SuccessBrush}" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
