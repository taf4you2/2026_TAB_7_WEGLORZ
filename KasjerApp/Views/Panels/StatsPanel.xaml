<UserControl x:Class="KasjerApp.Views.Panels.StatsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Statystyki dzisiaj" FontSize="22" FontWeight="Bold" Foreground="#1565C0" VerticalAlignment="Center"/>
            <Button Content="Odśwież" Click="RefreshBtn_Click"
                    Background="#1565C0" Foreground="White" BorderThickness="0"
                    Padding="16,7" Margin="20,0,0,0" FontSize="13" Cursor="Hand"/>
        </StackPanel>

        <!-- Karty statystyk -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,24">
            <Border Margin="0,0,12,0" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Bilety sprzedane" Foreground="#757575" FontSize="12"/>
                    <TextBlock x:Name="TicketsSoldText" Text="—" FontSize="32" FontWeight="Bold" Foreground="#1565C0" Margin="0,6,0,0"/>
                    <TextBlock Text="dzisiaj" Foreground="#BDBDBD" FontSize="11"/>
                </StackPanel>
            </Border>
            <Border Margin="6,0,6,0" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Aktywne karnety" Foreground="#757575" FontSize="12"/>
                    <TextBlock x:Name="ActivePassesText" Text="—" FontSize="32" FontWeight="Bold" Foreground="#2E7D32" Margin="0,6,0,0"/>
                    <TextBlock Text="aktualnie ważne" Foreground="#BDBDBD" FontSize="11"/>
                </StackPanel>
            </Border>
            <Border Margin="6,0,6,0" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Przychód zmiany" Foreground="#757575" FontSize="12"/>
                    <TextBlock x:Name="RevenueText" Text="—" FontSize="32" FontWeight="Bold" Foreground="#F57F17" Margin="0,6,0,0"/>
                    <TextBlock Text="PLN" Foreground="#BDBDBD" FontSize="11"/>
                </StackPanel>
            </Border>
            <Border Margin="12,0,0,0" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Oczekujące zwroty" Foreground="#757575" FontSize="12"/>
                    <TextBlock x:Name="PendingReturnsText" Text="—" FontSize="32" FontWeight="Bold" Foreground="#C62828" Margin="0,6,0,0"/>
                    <TextBlock Text="do obsłużenia" Foreground="#BDBDBD" FontSize="11"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Błąd -->
        <TextBlock x:Name="ErrorText" Grid.Row="2"
                   Foreground="#C62828" FontSize="13"
                   Visibility="Collapsed"/>
    </Grid>
</UserControl>
