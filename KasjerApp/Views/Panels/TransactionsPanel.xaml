<UserControl x:Class="KasjerApp.Views.Panels.TransactionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Historia transakcji" Style="{StaticResource PageTitleText}"/>

        <Border Grid.Row="1" Style="{StaticResource FilterPanel}">
            <WrapPanel>
                <TextBlock Text="Data:"
                           VerticalAlignment="Center"
                           Style="{StaticResource FieldLabelText}"
                           Margin="0,0,8,8"/>
                <DatePicker x:Name="DateFilter"
                            Width="160"
                            Margin="0,0,10,8"/>
                <Button Content="Szukaj"
                        Click="SearchBtn_Click"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,8,8"/>
                <Button Content="Wyczyść filtr"
                        Click="ClearBtn_Click"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,16,8"/>
                <TextBlock x:Name="MsgText"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource DangerBrush}"
                           Visibility="Collapsed"
                           Margin="0,0,0,8"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelCard}" Padding="0">
            <DataGrid x:Name="TransGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" MinWidth="60"/>
                    <DataGridTextColumn Header="Typ operacji" Binding="{Binding OperationType}" Width="160" MinWidth="140"/>
                    <DataGridTextColumn Header="Taryfa" Binding="{Binding Tariff}" Width="2*" MinWidth="170"/>
                    <DataGridTextColumn Header="Kwota (PLN)" Binding="{Binding Amount, StringFormat=N2}" Width="120" MinWidth="110"/>
                    <DataGridTextColumn Header="Data" Binding="{Binding Date, StringFormat=dd.MM.yyyy HH:mm}" Width="150" MinWidth="140"/>
                    <DataGridTextColumn Header="Kasjer" Binding="{Binding CashierLogin}" Width="*" MinWidth="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
